<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Zv3DLib" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="..\..\..\lib\gcc\debug\libZv3DLib" prefix_auto="1" extension_auto="1" />
				<Option working_dir="" />
				<Option object_output="..\..\..\intermediate\gcc\debug" />
				<Option type="2" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Compiler>
					<Add option="-Wall" />
					<Add option="-g" />
					<Add option="-DZV3D_DEBUG_LEVEL=3" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="..\..\..\lib\gcc\release\libZv3DLib" prefix_auto="1" extension_auto="1" />
				<Option working_dir="" />
				<Option object_output="..\..\..\intermediate\gcc\release" />
				<Option type="2" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Compiler>
					<Add option="-Wall" />
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-DZV3D_WINDOWS" />
			<Add directory="..\..\..\code\include" />
		</Compiler>
		<Unit filename="..\..\..\code\include\Zv3DDebug.h" />
		<Unit filename="..\..\..\code\include\Zv3DEndianness.h" />

<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="utf" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="..\..\..\..\bin\gcc\debug\utf" prefix_auto="1" extension_auto="1" />
				<Option working_dir="..\..\..\..\bin\gcc\debug" />
				<Option object_output="..\..\..\..\intermediate\gcc\debug\samples" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
				</Compiler>
				<Linker>
					<Add option="-lZv3DLib" />
					<Add directory="..\..\..\..\lib\gcc\debug" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin\Release\utf" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj\Release\" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add directory="..\..\..\..\code\include" />
		</Compiler>
		<Unit filename="..\..\..\..\code\include\samples\utf.h" />
		<Unit filename="..\..\..\..\code\source\samples\utf.cpp" />
		<Unit filename="..\..\..\..\code\source\samples\utf8.cpp" />
		<Extensions>
			<code_completion />
			<envvars />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
